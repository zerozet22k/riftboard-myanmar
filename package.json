{
  "name": "burmese-lp-ranking",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "server": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "discord:register": "node scripts/register-discord.mjs",
    "refresh:leaderboard:local": "node scripts/refresh-leaderboard-local.mjs",
    "refresh:leaderboard:ps": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-local-cron.ps1",
    "refresh:leaderboard:standalone": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-local-cron.ps1 -SyncMatches -MatchesCount 10",
    "refresh:service:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-refresh-service.ps1 -Limit 5 -IntervalSec 300 -SyncMatches -MatchesCount 10",
    "refresh:service:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-refresh-service.ps1"
  },
  "dependencies": {
    "mongoose": "^9.0.1",
    "next": "16.0.10",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
